@article{honeychurch2014AlternativeComplexitiesArchaeology,
  title = {Alternative {{Complexities}}: {{The Archaeology}} of {{Pastoral Nomadic States}}},
  shorttitle = {Alternative {{Complexities}}},
  author = {Honeychurch, William},
  year = 2014,
  month = dec,
  journal = {Journal of Archaeological Research},
  volume = {22},
  number = {4},
  pages = {277--326},
  issn = {1573-7756},
  doi = {10.1007/s10814-014-9073-9},
  urldate = {2025-07-08},
  abstract = {Almost a century of systematic anthropological research on pastoral nomads has produced significant data and theory for understanding these mobile societies. Substantially less attention has been devoted to complex sociopolitical organization among pastoral nomadic groups and, in particular, to the large-scale polities referred to as nomadic confederations, states, or sometimes empires. This article reviews established ideas for how and why complex organization emerged among nomadic groups and then considers these ideas in the context of recent archaeological theory on statehood and new material evidence for pastoral nomadic prehistory. Revised conceptions of both the state and the nomad suggest that pastoral nomadic polities represent alternative forms of complex organization that were different from classic Old World states but still quite complex in unexpected ways. These organizational differences resulted from the mobile and flexible politics practiced among herding peoples and gave rise to regional polities based on spatial networking, distributed authority, and innovations in transport and exchange.},
  langid = {english},
  keywords = {Anthropological Theory,Anthropology,Complexity,Ethnohistory,Historical Anthropology,Nomads,Pastoralism,Political and Economic Anthropology,States,Theoretical Archaeology}
}

@article{honeychurch2016ArchaeologyPastoralNomadism,
  title = {The {{Archaeology}} of {{Pastoral Nomadism}}},
  author = {Honeychurch, William and Makarewicz, Cheryl A.},
  year = 2016,
  month = oct,
  journal = {Annual Review of Anthropology},
  volume = {45},
  number = {1},
  pages = {341--359},
  publisher = {Annual Reviews},
  issn = {0084-6570, 1545-4290},
  doi = {10.1146/annurev-anthro-102215-095827},
  urldate = {2025-07-08},
  abstract = {Pastoral nomadism encompasses an array of specialized knowledge concerned with the daily rhythms and long-term tempos of caring for herd animals in order to extract subsistence livelihoods. It also embodies the relational lives of herders and the diverse ways in which herd animals structure the social and symbolic worlds of mobile pastoralists. This article reviews the latest research on ancient pastoral nomadic communities that is emerging in many parts of the world. We emphasize the importance of revolutionary advances in archaeological methods and biomolecular approaches that have made visible mobile pastoralist behaviors and decision-making processes previously concealed in the archaeological record. Archaeologists are gradually producing the high-resolution, multiscalar data sets required to link together the individual, community, and regional interactions that, over time, structured pastoral nomadic economies, social and ritual lives, and political organization.},
  langid = {english},
  file = {/Users/sarahalami/Zotero/storage/JNSUI8UF/Honeychurch and Makarewicz - 2016 - The Archaeology of Pastoral Nomadism.pdf;/Users/sarahalami/Zotero/storage/WHCRC9JQ/Honeychurch and Makarewicz - 2016 - The Archaeology of Pastoral Nomadism.pdf;/Users/sarahalami/Zotero/storage/7YWBVI8D/annurev-anthro-102215-095827.html}
}

