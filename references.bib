@article{manzano2021HolisticUnderstandingPastoralism,
  title = {Toward a {{Holistic Understanding}} of {{Pastoralism}}},
  author = {Manzano, Pablo and Burgas, Daniel and Cadah{\'i}a, Luis and Eronen, Jussi T. and {Fern{\'a}ndez-Llamazares}, {\'A}lvaro and Bencherif, Slimane and Holand, {\O}ystein and Seitsonen, Oula and Byambaa, Bayarmaa and Fortelius, Mikael and {Fern{\'a}ndez-Gim{\'e}nez}, Mar{\'i}a E. and Galvin, Kathleen A. and Cabeza, Mar and Stenseth, Nils Chr.},
  year = 2021,
  month = may,
  journal = {One earth (Cambridge, Mass.)},
  volume = {4},
  number = {5},
  pages = {651--665},
  issn = {25903322},
  doi = {10.1016/j.oneear.2021.04.012},
  urldate = {2025-04-07},
  abstract = {Pastoralism is globally significant in social, environmental, and economic terms. However, it experiences crises rooted in misconceptions and poor interdisciplinary understanding, while being largely overlooked in international sustainability forums and agendas. Here, we propose a transdisciplinary research approach to understand pastoralist transitions using (1) social, economic, and environmental dimensions, (2) diverse geographic contexts and scales to capture emerging properties, allowing for cross-system comparisons, and (3) timescales from the distant past to the present. We provide specific guidelines to develop indicators for this approach, within a social-ecological resilience analytical framework to understand change. Distinct systems undergo similar transitions over time, crossing critical thresholds and then either collapsing or recovering. Such an integrated view of multidimensional interactions improves understanding of possible tipping points, thereby supporting better-informed decision making. The need for a paradigm shift in pastoralism science and policy is pressing. This research approach, including participatory methods, can provide the solutions urgently needed.},
  langid = {english},
  file = {/Users/sarahalami/Zotero/storage/LSAH97CF/Manzano et al. - 2021 - Toward a holistic understanding of pastoralism.pdf}
}

