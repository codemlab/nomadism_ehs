@article{bencherifa1991ChangingResourceManagement,
  title = {Changing {{Resource Management Strategies}} and {{Their Environmental Impacts}} in the {{Middle Atlas Mountains}} of {{Morocco}}},
  author = {Bencherifa, Abdellatif and Johnson, Douglas L.},
  year = 1991,
  journal = {Mountain Research and Development},
  volume = {11},
  number = {3},
  eprint = {3673612},
  eprinttype = {jstor},
  pages = {183--194},
  publisher = {International Mountain Society},
  issn = {0276-4741},
  doi = {10.2307/3673612},
  urldate = {2025-07-19},
  abstract = {This paper discusses the social, economic, and ecological changes in terms of sustainable development in the mountain areas of North Africa. In many mountain ranges in Morocco, such as the Rif, the High Atlas, and the Anti Atlas, centuries old sedentary communities depended on terracing, cultivation of steep slopes, and intensive animal breeding. However, until the 1950s the northwestern section of the Middle Atlas was inhabited by semi-nomadic groups who depended on the summer pastures and in winter migrated to the surrounding lowlands in search of pasture and arable land. The paper recalls the cultural determinants behind these indigenous resource-use practices that no longer exist. During the last 35 years the pastoral nomadic migrations have disappeared; the people have settled permanently in the highlands for the first time and are engaged in a new pattern of agropastoral activities. The paper seeks explanation for the radical change in the perception and use of mountain resources. The detrimental impacts of these change processes endanger the viability of the natural resource base. /// Cet article porte sur la question du d\dbend veloppement permanent (ou viable) dans les r\dbend gions montagneuses de l'Afrique du Nord. A cette fin, l'exemple particulier de la cha\dbend ne du Moyen Atlas marocain est analys\dbend, vu que des changements sociaux, \dbend conomiques et \dbend cologiques importants s'y produisent depuis quelques d\dbend cennies. Contrairement aux autres montagnes marocaines (le Rif, le Haut Atlas et l'Anti Atlas) o\dbend{} la s\dbend dentarisation et la mise en valeur agropastorale des ressources de montagne sont des faits anciens, la partie nord-ouest du Moyen Atlas, jusqu'aux ann\dbend es cinquante, fut utilis\dbend e par divers groupes semi-nomades essentiellement comme p\dbend turages d'\dbend t\dbend, ces groupes se deplacant en hiver vers les bas-pays environnants en qu\dbend te de et/ou de terres cultivables, en suivant un rythme spatio-temporel bien r\dbend gl\dbend. Cet article rapelle de fa\dbend on succinte les d\dbend terminants \dbend cologiques et culturels qui expliquent ces pratiques anciennes de gestion des ressources dans cette montagne. Cependant, il accorde une importance plus grande aux changements intervenus dans la r\dbend gion lors des derni\dbend res 35 ann\dbend es. En effet, non seulement les anciennes migrations pastorales ont disparu, mais aussi (et surtout), une s\dbend dentarisation g\dbend n\dbend ralis\dbend e des populations dans les hauts-pays est intervenue. Aujourd'hui, ces populations se sont engag\dbend es dans les activit\dbend s agropastorales intensive et continues dans le temps. Cet article, tout en essayant d'expliquer l'origine des m\dbend canismes \dbend{} la base de ce changement radical, accorde une place privil\dbend gi\dbend e \dbend{} leurs cons\dbend quences \dbend cologiques n\dbend fastes, vu qu'elles menacent la viabilit\dbend{} \dbend{} moyen terme des ressources de la montagne. /// Diese Ver\dbend ffentlichung diskutiert soziale, \dbend konomische und \dbend kologische Ver\dbend nderungen im Sinne von langfristiger Entwicklung in den Berggebieten Nordafrikas. In vielen Bergketten Marokkos, wie dem Rif, dem Hohen Atlas und dem Anti-Atlas, waren die \dbend ber Jahrhunderte ans\dbend ssigen Gemeinden auf Terrassieren, Kultivieren steiler H\dbend nge und intensive Viehwirtschaft angewiesen. Bis in die 50er Jahre war der nordwestliche Teil des Mittleren Atlas mit semi-nomadischen Gruppen bev\dbend lkert, die auf Sommerweidewirtschaft angewiesen waren, und die im Winter auf der Suche nach Weide- und Ackerland in umliegende Tiefebenen auswichen. Die Ver\dbend ffentlichung bringt die nicht mehr existierenden, aber dennoch entscheidenden kulturellen Faktoren hinter diesen lokal\dbend blichen Gewohnheiten bei der Ressourcennutzung in Errinnerung. W\dbend hrend der vergangenen 35 Jahre haben die pastoralen, nomadischen Migrationen aufgeh\dbend rt; zum ersten Mal sind die Nomaden in den Hochlanden se\dbend haft geworden und betrieben eine neue Form der Weidewirtschaft. Die Arbeit sucht nach einer Erkl\dbend rung f\dbend r die radikalen \dbend nderungen in der Perzeption und Nutzung von Gebirgs-ressourcen. Die nachteiligen Auswirkungen dieser ver\dbend nderten Vorg\dbend nge gef\dbend hrden die \dbend berlebensf\dbend higkeit der Naturressourcen.}
}

